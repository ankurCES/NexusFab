# NexusFab environment — copy to .env and edit before use
# run.sh auto-copies this file if .env is missing

# ── Database ──────────────────────────────────────────────────────────────────
# Async SQLAlchemy URL (asyncpg driver required)
DATABASE_URL=postgresql+asyncpg://nexusfab:nexusfab@localhost:5432/nexusfab

# Sync URL for Alembic migrations (psycopg2 or pg8000)
# If unset, Alembic falls back to DATABASE_URL with driver swapped at runtime
SYNC_DATABASE_URL=postgresql://nexusfab:nexusfab@localhost:5432/nexusfab

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=8000

# ── Postgres (matches docker-compose.yml defaults) ────────────────────────────
POSTGRES_USER=nexusfab
POSTGRES_PASSWORD=nexusfab
POSTGRES_DB=nexusfab

# ── Simulation ────────────────────────────────────────────────────────────────
# Seed for reproducible sensor data (remove for random runs)
SENSOR_SEED=42
